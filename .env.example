# ========================================
# ZanChop - Environment Variables Example
# ========================================

# 1. Database (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/zanchop_db

# 2. Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WABA_ID=your_waba_id
VERIFY_TOKEN=your_custom_webhook_verify_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token

# 3. Paystack Integration
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/payment/callback

# 4. Africa's Talking (Optional for MVP)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox
AT_SENDER_PHONE=+233xxxxxxxxx

# 5. Cloudinary (Optional for MVP)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
